from django.db import models
from common.models import Base1


class Purchase(Base1):
    """
    Model to track purchases of products (e.g., clothes) by users
    Keeps record of who bought what, when, and at what price
    """
    
    PURCHASE_STATUS_CHOICES = [
        ('pending', 'Pending'),
        ('completed', 'Completed'),
        ('cancelled', 'Cancelled'),
        ('returned', 'Returned'),
    ]
    
    # Product being purchased
    product = models.ForeignKey(
        'crm.Product',
        on_delete=models.PROTECT,
        related_name='purchases',
        help_text="Product/Clothes being purchased"
    )
    
    # Purchaser
    user = models.ForeignKey(
        'auth.User',
        on_delete=models.PROTECT,
        related_name='purchases',
        help_text="User who made the purchase"
    )
    
    # Purchase details
    quantity = models.PositiveIntegerField(
        default=1,
        help_text="Quantity of items purchased"
    )
    
    unit_price = models.DecimalField(
        max_digits=12,
        decimal_places=2,
        help_text="Price per unit"
    )
    
    total_price = models.DecimalField(
        max_digits=12,
        decimal_places=2,
        help_text="Total price (quantity × unit_price)"
    )
    
    currency = models.ForeignKey(
        'crm.Currency',
        on_delete=models.SET_NULL,
        null=True,
        related_name='purchases',
        help_text="Currency of the purchase"
    )
    
    # Dates
    purchase_date = models.DateTimeField(
        auto_now_add=True,
        help_text="Date and time of purchase"
    )
    
    delivery_date = models.DateTimeField(
        null=True,
        blank=True,
        help_text="Expected or actual delivery date"
    )
    
    # Status
    status = models.CharField(
        max_length=20,
        choices=PURCHASE_STATUS_CHOICES,
        default='pending',
        help_text="Current status of the purchase"
    )
    
    # Additional details
    notes = models.TextField(
        blank=True,
        help_text="Additional notes about the purchase"
    )
    
    size = models.CharField(
        max_length=50,
        blank=True,
        help_text="Size (e.g., S, M, L, XL for clothes)"
    )
    
    color = models.CharField(
        max_length=100,
        blank=True,
        help_text="Color or variation"
    )
    
    payment_method = models.CharField(
        max_length=100,
        blank=True,
        help_text="Payment method used (e.g., Credit Card, Cash, etc.)"
    )
    
    invoice_number = models.CharField(
        max_length=100,
        blank=True,
        unique=True,
        help_text="Invoice/Receipt number"
    )
    
    class Meta:
        app_label = 'crm'
        ordering = ['-purchase_date']
        verbose_name = 'Purchase'
        verbose_name_plural = 'Purchases'
        indexes = [
            models.Index(fields=['user', '-purchase_date']),
            models.Index(fields=['product', '-purchase_date']),
            models.Index(fields=['status']),
        ]
    
    def __str__(self):
        return f"{self.user.get_full_name() or self.user.username} - {self.product.name} ({self.quantity}x) - {self.purchase_date.strftime('%Y-%m-%d')}"
    
    def save(self, *args, **kwargs):
        """Automatically calculate total price"""
        if self.unit_price and self.quantity:
            self.total_price = self.unit_price * self.quantity
        super().save(*args, **kwargs)
